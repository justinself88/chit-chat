PORT=3001

# Matchmaking abuse (server): max join-queue events per IP per window (in-memory; use a shared store if you scale horizontally).
# RATE_LIMIT_JOIN_QUEUE_MAX=40
# RATE_LIMIT_JOIN_QUEUE_WINDOW_MS=60000

# Optional: JSON array of ICE servers (add TURN for strict NAT / symmetric NAT).
# Example TURN (replace with your provider):
# ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:global.turn.example.com:3478","username":"user","credential":"pass"}]
# Optional: custom lobby stale timeout in ms (default 1800000 = 30 minutes)
# CUSTOM_LOBBY_TTL_MS=1800000
# Optional: server metrics log interval in ms (default 300000 = 5 minutes)
# METRICS_LOG_EVERY_MS=300000

# --- Socket.IO auth hardening (server runtime) ---
# To enforce Firebase ID token verification on Socket.IO:
# 1) provide Firebase Admin credentials via one of:
#    - FIREBASE_ADMIN_SERVICE_ACCOUNT (JSON string OR base64-encoded JSON), OR
#    - GOOGLE_APPLICATION_CREDENTIALS (path to service-account JSON on host)
# 2) set REQUIRE_FIREBASE_TOKEN=true
# If REQUIRE_FIREBASE_TOKEN is false/missing, server allows local dev fallback.
# REQUIRE_FIREBASE_TOKEN=true
# FIREBASE_ADMIN_SERVICE_ACCOUNT=

# --- Firebase (client / Vite — must use VITE_ prefix) ---
# Create a Web app in Firebase Console → Project settings → Your apps.
# Enable: Authentication → Sign-in method → Email/Password (required for Chit Chat).
# The app does not use Firebase Anonymous sign-in; use email/password accounts only.
# Firestore: create database (test mode ok for first try; then use firestore.rules in repo).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional — enables Firebase Analytics (same as measurementId in Console config)
VITE_FIREBASE_MEASUREMENT_ID=

# Public contact email shown in Privacy Policy (mailto link when set)
# VITE_CONTACT_EMAIL=privacy@yourdomain.com
